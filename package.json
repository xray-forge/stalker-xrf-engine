{
  "name": "stalker-xrf-engine",
  "version": "1.0.0",
  "author": "Neloreck",
  "repository": "https://github.com/xray-forge/stalker-xrf-engine",
  "private": true,
  "scripts": {
    "cli": "ts-node -P ./cli/tsconfig.json cli/run.ts",
    "setup": "git submodule update --init --recursive",
    "verify": "ts-node -P ./cli/tsconfig.json cli/run.ts verify project",
    "build": "ts-node -P cli/tsconfig.json cli/run.ts build",
    "pack:mod": "ts-node -P cli/tsconfig.json cli/run.ts pack mod -c -o",
    "pack:game": "ts-node -P cli/tsconfig.json cli/run.ts pack game -c -o",
    "watch:scripts": "tstl -P ./cli/build/tsconfig.scripts.json --watch",
    "watch:scripts-tracy": "npx cross-env XR_INJECT_TRACY_ZONES=true tstl -P ./cli/build/tsconfig.scripts.json --watch",
    "watch:scripts-optimized": "npx cross-env XR_NO_LUA_LOGS=true tstl -P ./cli/build/tsconfig.scripts.json --watch",
    "watch:scripts-tracy-optimized": "npx cross-env XR_INJECT_TRACY_ZONES=true XR_NO_LUA_LOGS=true tstl -P ./cli/build/tsconfig.scripts.json --watch",
    "typecheck": "tstl -P ./cli/build/tsconfig.scripts.json --noEmit",
    "typecheck:tests": "tsc -p ./cli/test/tsconfig.tests.json",
    "format": "prettier --write \"**/*.(js|ts|tsx|md)\" \"!cli/bin/**/*\" && npm run lint -- --fix && npm run cli format ltx",
    "lint": "eslint . --config cli/lint/eslint.config.mjs --cache --cache-location target/eslint/cache.json",
    "lint:strict": "eslint . --config cli/lint/eslint.config.strict.mjs",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "help": "ts-node -P ./cli/tsconfig.json cli/run.ts -h"
  },
  "dependencies": {
    "xray16": "1.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@jest/globals": "^30.4.1",
    "@types/ini": "^4.1.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.6.0",
    "@typescript-to-lua/language-extensions": "^1.19.0",
    "chalk": "4.1.2",
    "commander": "^13.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsdoc": "^63.0.10",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-sort-keys-fix": "^1.1.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "fast-xml-parser": "^5.9.3",
    "fengari": "0.1.5",
    "globals": "^15.0.0",
    "iconv-lite": "^0.7.2",
    "ini": "^5.0.0",
    "jest": "^30.4.2",
    "jsdom": "^29.1.1",
    "jsx-xml": "0.2.3",
    "lua-types": "^2.14.1",
    "prettier": "^3.9.3",
    "steam-path": "^1.0.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.62.0",
    "typescript-to-lua": "^1.37.0"
  },
  "bin": {
    "xrf": "./cli/run.ts"
  },
  "jest": {
    "preset": "./cli/test/jest.config.ts"
  }
}
