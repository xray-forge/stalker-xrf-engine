{
  "extends": "../../src/tsconfig.json",
  "compilerOptions": {
    "jsx": "react",
    "rootDir": "../../src/engine",
    "outDir": "../../target/gamedata",
    "ignoreDeprecations": "6.0",
    "paths": {
      "#/*": ["../../cli/*"],
      "@/*": ["../*"],
      "xray16/lib": ["../../node_modules/xray16/lib/index"]
    }
  },
  "include": ["../../src/engine/lib", "../../src/engine/scripts", "../../src/engine/extensions"],
  "exclude": ["../../**/*.test.ts"],
  "tstl": {
    "buildMode": "default",
    "extension": ".script",
    "noHeader": true,
    "luaTarget": "JIT",
    "noImplicitGlobalVariables": true,
    "noImplicitSelf": true,
    "noResolvePaths": ["xray16", "xray16/macros", "xray16/alias"],
    "luaPlugins": [
      { "name": "xray16/plugins/inline" },
      { "name": "xray16/plugins/luabind" },
      { "name": "xray16/plugins/macros" },
      { "name": "xray16/plugins/optimize" },
      { "name": "xray16/plugins/strip" },
      { "name": "xray16/plugins/tracy" },
      { "name": "xray16/plugins/libcompile" }
    ]
  }
}
