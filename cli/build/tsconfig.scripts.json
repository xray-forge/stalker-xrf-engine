{
  "extends": "../../src/tsconfig.json",
  "compilerOptions": {
    "jsx": "react",
    "rootDir": "../../src/engine",
    "outDir": "../../target/gamedata",
    "ignoreDeprecations": "6.0"
  },
  "include": ["../../src/typedefs", "../../src/engine/lib", "../../src/engine/scripts", "../../src/engine/extensions"],
  "exclude": ["../../**/*.test.ts"],
  "tstl": {
    "buildMode": "default",
    "extension": ".script",
    "noHeader": true,
    "luaTarget": "JIT",
    "noImplicitGlobalVariables": true,
    "noImplicitSelf": true,
    "noResolvePaths": ["xray16"],
    "luaPlugins": [
      { "name": "xray16/plugins/inline" },
      { "name": "xray16/plugins/luabind" },
      { "name": "xray16/plugins/macros" },
      { "name": "xray16/plugins/optimize" },
      { "name": "xray16/plugins/strip" },
      { "name": "xray16/plugins/tracy" }
    ]
  }
}
