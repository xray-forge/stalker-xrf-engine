[logic]
$scheme = $logic
active = sr_idle@enable

[sr_idle@enable]
$scheme = $sr_idle
on_info = {+zat_b57_gas_running_play} sr_particle@flood

[sr_particle@flood]
$scheme = $sr_particle
name = industrial_particles\effects\exhaust_workshop_1_small
path = zat_b57_place_gas_point
mode = 2
looped = true
on_info = {+zat_b57_gas_running_stop} sr_idle@end

[sr_idle@end]
$scheme = $sr_idle
