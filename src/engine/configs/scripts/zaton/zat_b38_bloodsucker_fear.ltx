[logic]
$scheme = $logic
active = sr_idle@fear

[sr_idle@fear]
$scheme = $sr_idle
on_info = {+zat_b38_scary_sound} sr_idle@signal %=play_sound(zat_b38_bloodsucker_roar)%

[sr_idle@signal]
$scheme = $sr_idle
on_signal = sound_end | sr_idle@timer

[sr_idle@timer]
$scheme = $sr_idle
on_game_timer = 30 | {+zat_b38_illusion} sr_idle@end %+zat_b38_time_to_say_illusion%

[sr_idle@end]
$scheme = $sr_idle
