[logic]
$scheme = $logic
active = sr_psy_antenna@check_antena_destroy

[sr_psy_antenna@check_antena_destroy]
$scheme = $sr_psy_antenna
eff_intensity = 55
hit_intensity = 0.6
hit_freq = 100
on_info = {+pri_a25_antenna_destroyed} sr_psy_antenna@nil
postprocess = psi.ppe
no_static = true

[sr_psy_antenna@nil]
$scheme = $sr_psy_antenna
eff_intensity = 0
hit_intensity = 0
no_static = true
