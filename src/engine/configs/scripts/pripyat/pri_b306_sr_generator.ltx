[logic]
active = sr_idle@wait_for_start

[sr_idle@wait_for_start]
$scheme = $sr_idle
on_actor_inside = sr_idle@run %=run_tutorial(pri_b306_generator)%
on_info = {+pri_b306_lift_generator_used} sr_idle@end %=play_sound(pri_b306_generator_start)%

[sr_idle@run]
$scheme = $sr_idle
on_actor_outside = sr_idle@wait_for_start %=stop_tutorial%
on_info = {-pri_b306_lift_generator_used !has_active_tutorial} sr_idle@wait_for_start
on_info2 = {+pri_b306_lift_generator_used} sr_idle@end %=play_sound(pri_b306_generator_start)%

[sr_idle@end]
$scheme = $sr_idle
on_game_timer = 30 | sr_idle@after %+pri_b306_lift_generator_started =play_sound_looped(pri_b306_generator_work)%

[sr_idle@after]
$scheme = $sr_idle
