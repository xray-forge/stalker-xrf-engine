[logic]
active = sr_idle@wait

[sr_idle@wait]
$scheme = $sr_idle
on_info = {+jup_b219_start_sound} sr_idle@timer

[sr_idle@timer]
$scheme = $sr_idle
on_game_timer = 70 | sr_idle@looped %=play_sound(jup_b219_generator_start)%

[sr_idle@looped]
$scheme = $sr_idle
on_signal = sound_end | sr_idle@stop_looped %+jup_b219_generator_looped_done =play_sound_looped(jup_b219_generator_looped)%

[sr_idle@stop_looped]
$scheme = $sr_idle
on_info = {+jup_b219_destroy_actor} sr_idle@timer_to_stop

[sr_idle@timer_to_stop]
$scheme = $sr_idle
on_timer = 6000 | sr_idle@nil %=stop_sound_looped%

[sr_idle@nil]
$scheme = $sr_idle
