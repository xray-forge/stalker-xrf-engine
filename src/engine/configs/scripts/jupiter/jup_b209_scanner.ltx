[collide]
ignore_static

[logic]
$scheme = $logic
active = ph_idle

[ph_idle]
$scheme = $ph_idle
nonscript_usable = true
on_info = {+jup_b209_scanner_time_to_remove} ph_idle@remove

[ph_idle@remove]
$scheme = $ph_idle
tips = jup_b209_scanner_remove_tips
on_use = %+jup_b209_scanner_remove =destroy_object%
